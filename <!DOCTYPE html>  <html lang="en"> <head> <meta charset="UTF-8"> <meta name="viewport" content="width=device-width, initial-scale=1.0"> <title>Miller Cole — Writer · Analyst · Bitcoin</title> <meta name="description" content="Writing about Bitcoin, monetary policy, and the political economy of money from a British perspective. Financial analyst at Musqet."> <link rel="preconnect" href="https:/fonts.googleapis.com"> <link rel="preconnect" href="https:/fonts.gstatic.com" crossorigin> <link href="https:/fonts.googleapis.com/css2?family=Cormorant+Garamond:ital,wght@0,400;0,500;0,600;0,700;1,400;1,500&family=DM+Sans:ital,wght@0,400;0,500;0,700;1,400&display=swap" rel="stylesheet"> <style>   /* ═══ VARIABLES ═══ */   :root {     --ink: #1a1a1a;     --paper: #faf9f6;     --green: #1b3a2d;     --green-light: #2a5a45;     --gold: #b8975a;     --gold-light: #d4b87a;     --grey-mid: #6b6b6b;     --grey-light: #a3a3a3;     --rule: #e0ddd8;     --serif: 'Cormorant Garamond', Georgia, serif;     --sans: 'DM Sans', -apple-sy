<style>
  /* ═══ VARIABLES ═══ */
  :root {
    --ink: #1a1a1a;
    --paper: #faf9f6;
    --green: #1b3a2d;
    --green-light: #2a5a45;
    --gold: #b8975a;
    --gold-light: #d4b87a;
    --grey-mid: #6b6b6b;
    --grey-light: #a3a3a3;
    --rule: #e0ddd8;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'DM Sans', -apple-system, sans-serif;
  }

/* ═══ RESET & BASE ═══ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html {
font-size: 17px;
scroll-behavior: smooth;
}

body {
font-family: var(–sans);
background: var(–paper);
color: var(–ink);
line-height: 1.6;
-webkit-font-smoothing: antialiased;
}

.container {
max-width: 960px;
margin: 0 auto;
padding: 0 2rem;
}

a { color: inherit; }

/* ═══ TOP BAR ═══ */
.top-bar {
border-bottom: 1px solid var(–rule);
padding: 0.6rem 0;
font-size: 0.72rem;
text-transform: uppercase;
letter-spacing: 1.5px;
color: var(–grey-mid);
}

.top-bar .container {
display: flex;
justify-content: space-between;
align-items: center;
}

.top-bar-links {
display: flex;
gap: 1.2rem;
}

.top-bar-links a {
text-decoration: none;
color: var(–grey-mid);
transition: color 0.2s;
}

.top-bar-links a:hover { color: var(–ink); }

/* ═══ HEADER ═══ */
header {
padding: 3.5rem 0 2rem;
text-align: center;
border-bottom: 2px solid var(–ink);
}

header h1 {
font-family: var(–serif);
font-size: 3.4rem;
font-weight: 600;
letter-spacing: -0.5px;
line-height: 1.1;
}

.tagline {
font-family: var(–sans);
font-size: 0.82rem;
text-transform: uppercase;
letter-spacing: 3px;
color: var(–grey-mid);
margin-top: 0.6rem;
}

nav.main-nav {
margin-top: 1.8rem;
display: flex;
justify-content: center;
gap: 2rem;
}

nav.main-nav a {
font-size: 0.78rem;
text-transform: uppercase;
letter-spacing: 1.5px;
text-decoration: none;
color: var(–grey-mid);
transition: color 0.2s;
}

nav.main-nav a:hover { color: var(–ink); }

/* ═══ HERO / ABOUT ═══ */
.hero {
padding: 4rem 0 3rem;
border-bottom: 1px solid var(–rule);
}

.hero-layout {
display: grid;
grid-template-columns: 1.2fr 1fr;
gap: 3rem;
align-items: start;
}

.hero-intro {
font-family: var(–serif);
font-size: 1.65rem;
font-weight: 400;
line-height: 1.45;
color: var(–ink);
}

.hero-intro em {
color: var(–green);
font-style: italic;
}

.hero-bio {
font-size: 0.92rem;
line-height: 1.7;
color: var(–grey-mid);
}

.hero-bio p + p { margin-top: 0.8rem; }

.hero-credentials {
margin-top: 2rem;
padding-top: 1.5rem;
border-top: 1px solid var(–rule);
display: flex;
gap: 2.5rem;
}

.credential {
font-size: 0.72rem;
text-transform: uppercase;
letter-spacing: 1.2px;
color: var(–grey-light);
}

.credential strong {
display: block;
font-family: var(–serif);
font-size: 1.3rem;
font-weight: 600;
color: var(–ink);
letter-spacing: 0;
text-transform: none;
margin-bottom: 0.15rem;
}

/* ═══ FEATURED IN ═══ */
.featured {
padding: 2rem 0;
border-bottom: 1px solid var(–rule);
text-align: center;
}

.featured-label {
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 2px;
color: var(–grey-light);
margin-bottom: 1rem;
}

.featured-logos {
display: flex;
justify-content: center;
gap: 2.5rem;
align-items: center;
}

.featured-logos span {
font-family: var(–serif);
font-size: 1.15rem;
font-weight: 600;
color: var(–grey-mid);
letter-spacing: 0.3px;
}

.featured-logos span::after {
content: ‘’;
display: none;
}

/* ═══ SECTION HEADINGS ═══ */
.section-heading {
padding: 3rem 0 1.5rem;
}

.section-heading h2 {
font-family: var(–serif);
font-size: 2rem;
font-weight: 600;
}

.section-number {
font-family: var(–sans);
font-size: 0.68rem;
text-transform: uppercase;
letter-spacing: 2px;
color: var(–gold);
display: block;
margin-bottom: 0.3rem;
}

/* ═══ SERVICES ═══ */
.services-grid {
display: grid;
grid-template-columns: 1fr 1fr;
border-top: 1px solid var(–rule);
}

.service-card {
padding: 2rem 2rem 2rem 0;
border-bottom: 1px solid var(–rule);
opacity: 0;
animation: fadeUp 0.5s ease-out both;
}

.service-card:nth-child(even) {
padding-left: 2rem;
border-left: 1px solid var(–rule);
}

.service-card:nth-child(odd) {
border-right: 1px solid var(–rule);
}

.service-number {
font-family: var(–sans);
font-size: 0.68rem;
letter-spacing: 2px;
color: var(–gold);
margin-bottom: 0.8rem;
}

.service-card h3 {
font-family: var(–serif);
font-size: 1.3rem;
font-weight: 600;
margin-bottom: 0.5rem;
}

.service-card p {
font-size: 0.88rem;
color: var(–grey-mid);
line-height: 1.6;
}

.pricing-cta {
text-align: center;
padding: 2rem 0 3rem;
border-bottom: 1px solid var(–rule);
}

.pricing-btn {
display: inline-block;
font-family: var(–sans);
font-size: 0.78rem;
text-transform: uppercase;
letter-spacing: 2px;
text-decoration: none;
color: var(–paper);
background: var(–green);
padding: 0.9rem 2.5rem;
transition: background 0.2s;
}

.pricing-btn:hover { background: var(–green-light); }

/* ═══ WRITING LIST ═══ */
.writing-list {
list-style: none;
border-top: 1px solid var(–rule);
}

.writing-item {
display: flex;
align-items: center;
justify-content: space-between;
padding: 1.2rem 0;
border-bottom: 1px solid var(–rule);
text-decoration: none;
transition: padding-left 0.25s ease;
opacity: 0;
animation: fadeUp 0.5s ease-out both;
}

.writing-item:nth-child(1) { animation-delay: 0.1s; }
.writing-item:nth-child(2) { animation-delay: 0.18s; }
.writing-item:nth-child(3) { animation-delay: 0.26s; }
.writing-item:nth-child(4) { animation-delay: 0.34s; }
.writing-item:nth-child(5) { animation-delay: 0.42s; }

.writing-item:hover {
padding-left: 0.8rem;
}

.writing-title {
font-family: var(–serif);
font-size: 1.15rem;
font-weight: 500;
flex: 1;
}

.writing-meta {
display: flex;
gap: 1.2rem;
align-items: center;
margin-left: 1.5rem;
flex-shrink: 0;
}

.writing-pub {
font-size: 0.72rem;
text-transform: uppercase;
letter-spacing: 1.2px;
color: var(–gold);
}

.writing-date {
font-size: 0.72rem;
text-transform: uppercase;
letter-spacing: 1.2px;
color: var(–grey-light);
}

.writing-arrow {
margin-left: 1rem;
color: var(–grey-light);
font-size: 1.1rem;
transition: color 0.2s, transform 0.2s;
}

.writing-item:hover .writing-arrow {
color: var(–green);
transform: translateX(3px);
}

/* ═══ NEWSLETTER ═══ */
.newsletter {
background: var(–green);
color: var(–paper);
padding: 4rem 0;
margin-top: 3rem;
}

.newsletter-inner {
max-width: 960px;
margin: 0 auto;
padding: 0 2rem;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 3rem;
align-items: center;
}

.newsletter h2 {
font-family: var(–serif);
font-size: 2rem;
font-weight: 600;
margin-bottom: 0.5rem;
}

.newsletter p {
font-size: 0.92rem;
opacity: 0.8;
line-height: 1.6;
}

.nl-form {
display: flex;
}

.nl-form input[type=“email”] {
flex: 1;
padding: 0.8rem 1rem;
border: 1px solid rgba(255,255,255,0.15);
border-right: none;
background: rgba(255,255,255,0.07);
color: var(–paper);
font-family: var(–sans);
font-size: 0.88rem;
outline: none;
}

.nl-form input::placeholder { color: rgba(255,255,255,0.4); }

.nl-form button {
padding: 0.8rem 1.8rem;
background: var(–gold);
color: var(–green);
border: none;
font-family: var(–sans);
font-size: 0.78rem;
font-weight: 700;
text-transform: uppercase;
letter-spacing: 1.5px;
cursor: pointer;
transition: background 0.2s;
}

.nl-form button:hover { background: var(–gold-light); }

.nl-note {
font-size: 0.72rem;
opacity: 0.5;
margin-top: 0.6rem;
}

/* ═══ FOOTER ═══ */
footer {
padding: 3rem 0 2rem;
border-top: 1px solid var(–rule);
}

.footer-grid {
display: grid;
grid-template-columns: 1.5fr 1fr;
gap: 3rem;
}

.footer-heading {
font-family: var(–serif);
font-size: 1.3rem;
font-weight: 600;
margin-bottom: 0.8rem;
}

.email-link {
display: inline-block;
font-family: var(–serif);
font-size: 1.15rem;
color: var(–green);
text-decoration: none;
border-bottom: 1px solid var(–green);
margin-bottom: 0.8rem;
transition: opacity 0.2s;
}

.email-link:hover { opacity: 0.7; }

footer p {
font-size: 0.88rem;
color: var(–grey-mid);
line-height: 1.6;
}

.footer-links {
display: flex;
flex-direction: column;
gap: 0.8rem;
justify-content: center;
}

.footer-link {
font-size: 0.78rem;
text-transform: uppercase;
letter-spacing: 1px;
color: var(–grey-mid);
text-decoration: none;
transition: color 0.2s;
}

.footer-link:hover { color: var(–ink); }

.footer-copy {
margin-top: 2.5rem;
padding-top: 1.5rem;
border-top: 1px solid var(–rule);
font-size: 0.72rem;
color: var(–grey-light);
text-align: center;
}

/* ═══ ANIMATIONS ═══ */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(15px); }
to { opacity: 1; transform: translateY(0); }
}

.hero-intro { animation: fadeUp 0.7s ease-out; }
.hero-bio { animation: fadeUp 0.7s ease-out 0.1s both; }
.hero-credentials { animation: fadeUp 0.7s ease-out 0.2s both; }

.service-card:nth-child(1) { animation-delay: 0.2s; }
.service-card:nth-child(2) { animation-delay: 0.3s; }
.service-card:nth-child(3) { animation-delay: 0.4s; }
.service-card:nth-child(4) { animation-delay: 0.5s; }

/* ═══ RESPONSIVE ═══ */
